+def build_openssl():
+    if is_installed('ssl') and is_installed('crypto'):
+        print('openssl already installed. Skipping.')
+        return
+    src_dir = download_and_extract('openssl', URLS['openssl'])
+    
+    ca_bundle_path = os.path.join(PREFIX, 'cert.pem')
+    if not os.path.exists(ca_bundle_path):
+        print('Downloading cacert.pem...')
+        urllib.request.urlretrieve("https://curl.se/ca/cacert.pem", ca_bundle_path)
+        
+    arch = platform.machine()
+    if arch == 'arm64':
+        target = 'darwin64-arm64-cc'
+    else:
+        target = 'darwin64-x86_64-cc'
+        
+    args = [
+        'perl', './Configure',
+        f'--prefix={PREFIX}',
+        f'--openssldir={PREFIX}',
+        '--libdir=lib',
+        'no-ssl3',
+        'no-ssl3-method',
+        'no-zlib',
+        target,
+        'enable-ec_nistp_64_gcc_128'
+    ]
+    
+    run_command(args, src_dir)
+    run_command(['make', '-j4'], src_dir)
+    run_command(['make', 'install_sw'], src_dir)
+
+
